---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - 页面未找到 - 一心" description="页面未找到">
  <div class="not-found">
    <h1>404</h1>
    <p>页面未找到</p>
    <p>
      <a href="/">返回首页</a>
    </p>
  </div>

  <style>
    .not-found {
      text-align: center;
      padding: 3rem 0;
    }

    h1 {
      margin: 0 0 1rem;
      font-size: 3em;
      color: #999999;
    }

    p {
      color: #666666;
    }
  </style>
</BaseLayout>
