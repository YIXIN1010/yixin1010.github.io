        </div>
      </div>
      <div class="ai-chat-input-area">
        <input type="text" class="ai-chat-input" id="aiChatInput" placeholder="输入消息..." />
        <button class="ai-chat-send" id="aiChatSend">发送</button>
      </div>
    </div>

    <div class="heatmap-section">
      <h2 class="section-title">📊 年度发文统计</h2>
      <div class="heatmap-container">
        <div class="heatmap-grid">
          {weeks.map((week) => (
            <div class="heatmap-column">
              {week.map((day) => {
                if (!day) {
                  return <div class="heatmap-day empty"></div>;
                }
                const dateStr = `${day.getFullYear()}-${String(day.getMonth() + 1).padStart(2, '0')}-${String(day.getDate()).padStart(2, '0')}`;
                const count = heatmapData[dateStr] || 0;
                return (
                  <div 
                    class="heatmap-day" 
                    style={{ backgroundColor: getColorIntensity(count) }}
                    title={`${day.getMonth() + 1}/${day.getDate()}: ${count}篇`}
                  ></div>
                );
              })}
            </div>
          ))}
        </div>
        <div class="heatmap-legend">
          <span class="legend-label">少</span>
          {['#ebedf0', '#c6e48b', '#7bc96f', '#239a3b', '#196127'].map((color) => (
            <div class="legend-block" style={{ backgroundColor: color }}></div>
          ))}
          <span class="legend-label">多</span>
        </div>
      </div>
    </div>

    <div class="quick-nav">
      <h2 class="section-title">📚 专栏导航</h2>
      <div class="nav-grid">
        <a href="/columns/随笔生活" class="nav-item life">
