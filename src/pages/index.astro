            <rect x="1" y="1" width="22" height="15" rx="2" ry="2"></rect>
            <line x1="1" y1="21" x2="23" y2="21"></line>
            <line x1="8" y1="21" x2="8" y2="15"></line>
            <line x1="16" y1="21" x2="16" y2="15"></line>
          </svg>
          <span>技术笔记</span>
        </a>
        <a href="/columns/工具收藏" class="nav-item tools">
