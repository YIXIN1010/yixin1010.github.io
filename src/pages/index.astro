        </a>
      </div>
    </div>

    <div class="posts-section">
      <h2 class="section-title">📝 专栏更新</h2>
      <div class="category-posts">
        {categories.map((category) => {
          const post = latestPostsByCategory[category];
          const date = post ? new Date(post.data.date) : null;
          const formattedDate = date ? `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}` : '';
          
          return (
            <div class="category-section">
              <h3 class="category-title">
                <span class="category-icon">{getCategoryIcon(category)}</span>
                <span>{category}</span>
