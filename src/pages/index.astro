      </div>
    </div>

    <!-- AI 聊天按钮 -->
    <div class="ai-chat-fab" id="aiChatFab">
      <span class="ai-fab-icon">🤖</span>
      <span class="ai-fab-tooltip">AI 对话</span>
    </div>

    <!-- AI 聊天窗口 -->
    <div class="ai-chat-window" id="aiChatWindow">
      <div class="ai-chat-header-bar">
        <div class="ai-chat-title">
          <span class="ai-chat-icon">🤖</span>
          <span>AI 助手</span>
        </div>
        <button class="ai-chat-close" id="aiChatClose">×</button>
      </div>
