      padding: 0;
      background: transparent;
      border-radius: 0;
    }

    .post-category {
      display: inline-flex;
      font-size: 0.85em;
      padding: 0;
      background: transparent;
      color: #0066CC;
      border-radius: 0;
      font-weight: 500;
    }

    .post-title {
      margin: 0 0 0.75rem;
      font-size: 1.35em;
      font-weight: 600;
    }

    .post-title a {
      color: #1A1A1A;
      text-decoration: none;
    }

