---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DigitalAvatarChat from '../components/DigitalAvatarChat.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={Astro.props.description ?? '一个用于记录生活、阅读、技术和思考的个人博客。'} />
    <meta property="og:title" content={Astro.props.title} />
    <meta property="og:description" content={Astro.props.description ?? '一个用于记录生活、阅读、技术和思考的个人博客。'} />
    <meta property="og:type" content="website" />
    <link rel="alternate" type="application/atom+xml" href="/atom.xml" title="一心" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{Astro.props.title}</title>
  </head>
  <body>
    <div class="container">
      <Header />
      <main><slot /></main>
      <Footer />
    </div>
    <DigitalAvatarChat />
    <style>
      .container {
        max-width: 800px;
        margin: 0;
        padding: 0 1.25rem;
        margin-left: auto;
        margin-right: auto;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main {
        flex: 1;
        padding: 2rem 0;
      }

      @media (min-width: 768px) {
        .container {
          padding: 0 2rem;
          margin-left: 0;
          margin-right: auto;
          max-width: calc(100% - 4rem);
        }
        
        main {
          padding: 3rem 0;
        }
      }
      
      @media (min-width: 1024px) {
        .container {
          margin-left: 5%;
          margin-right: auto;
          max-width: 900px;
        }
      }
    </style>
  </body>
</html>
