<footer>
  <div class="footer-content">
    <p class="copyright">© 2026 一心. All rights reserved.</p>
  </div>
  <style>
    footer {
      padding: 2rem 0;
      border-top: 1px solid #E5E5E5;
      margin-top: auto;
    }

    .footer-content {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      align-items: flex-start;
    }

    .copyright {
      margin: 0;
      color: #999999;
      font-size: 0.85em;
    }

    @media (min-width: 768px) {
      .footer-content {
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
      }
    }
  </style>
</footer>
