<script>
  // 配置区域 - 请替换为你的 Cloudflare Worker 地址
  const API_URL = "https://restless-unit-4bc0.411313795.workers.dev";
  const TEMPERATURE = 0.7;
  const MAX_HISTORY_MESSAGES = 10;

  // System Prompt - 数字分身身份定义
  const systemPrompt = `你是一心博客的数字分身。

你的身份：
- 你是一个结构化、务实、注重长期积累的 AI 助手。
- 你擅长 AI 工具、知识管理、个人博客、Astro、GitHub Pages、Prompt Engineering、RAG、流程优化和工作流优化。
- 你的回答风格像一个理性、耐心、实用的个人顾问。

表达要求：
- 使用简体中文回答。
- 先给结论，再给步骤。
- 多使用小标题、列表和清晰结构。
- 不要空泛，要给出可执行建议。
- 技术问题要同时说明"为什么"和"怎么做"。
- 如果信息不足，先基于最可能的意图给出方案，并说明可以继续细化。
- 不要夸张，不要营销化，不要编造事实。

如果页面中读取到了当前文章内容，你需要优先结合当前文章内容回答；如果文章内容不足，再给通用建议。`;

  // 安全注意：
  // 当前前端只调用 Cloudflare Worker 代理地址。
  // 不要在前端代码中写入火山方舟 API Key。
  // 正式环境应将 ARK_API_KEY 和 ARK_MODEL 存放在 Cloudflare Worker Secret 中。
  // 不要把 .env、.dev.vars 或任何包含密钥的文件提交到 GitHub。

  document.addEventListener('DOMContentLoaded', () => {
    const chatButton = document.getElementById('avatar-chat-button');
    const chatWindow = document.getElementById('avatar-chat-window');
    const closeButton = document.getElementById('avatar-close-btn');
    const sendButton = document.getElementById('avatar-send-btn');
    const inputField = document.getElementById('avatar-input');
    const messagesContainer = document.getElementById('avatar-messages');
    const clearButton = document.getElementById('avatar-clear-btn');
    const loadingIndicator = document.getElementById('avatar-loading');

    let historyMessages = [];

    // 读取当前页面文章内容作为上下文
    function getPageContext() {
      const article = document.querySelector('article');
      if (article) {
        const text = article.innerText || '';
        return text.substring(0, 1500);
      }
      return '';
    }

    // 切换聊天窗口显示/隐藏
    function toggleChat() {
      chatWindow.classList.toggle('avatar-hidden');
      chatButton.classList.toggle('avatar-hidden');
    }

    // 关闭聊天窗口
    function closeChat() {
      chatWindow.classList.add('avatar-hidden');
      chatButton.classList.remove('avatar-hidden');
    }

    // 添加消息到消息列表
    function addMessage(content, isUser, isError = false) {
      const messageDiv = document.createElement('div');
      messageDiv.className = `avatar-message ${isUser ? 'avatar-user' : 'avatar-ai'} ${isError ? 'avatar-error' : ''}`;
      
      const bubble = document.createElement('div');
      bubble.className = `avatar-bubble ${isUser ? 'avatar-user-bubble' : 'avatar-ai-bubble'}`;
      bubble.textContent = content;
      
      messageDiv.appendChild(bubble);
      messagesContainer.appendChild(messageDiv);
      scrollToBottom();
    }

    // 滚动到底部
    function scrollToBottom() {
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    // 清空对话
    function clearChat() {
      messagesContainer.innerHTML = '';
      historyMessages = [];
    }

    // 发送消息
    async function sendMessage() {
      const userInput = inputField.value.trim();
      if (!userInput) return;

      // 显示用户消息
      addMessage(userInput, true);
      inputField.value = '';

      // 显示加载状态
      loadingIndicator.classList.remove('avatar-hidden');
      sendButton.disabled = true;

      try {
        // 获取页面上下文
        const pageContext = getPageContext();
        let contextPrompt = systemPrompt;
        if (pageContext) {
          contextPrompt += `\n\n当前页面内容参考（前1500字）：\n${pageContext}`;
        }

        // 构建请求消息
        const requestMessages = [
          { role: 'system', content: contextPrompt },
          ...historyMessages,
          { role: 'user', content: userInput }
        ];

        // 调用 Cloudflare Worker（前端只发送 messages 和 temperature）
        const response = await fetch(API_URL, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            messages: requestMessages,
            temperature: TEMPERATURE
          })
        });

        // 隐藏加载状态
        loadingIndicator.classList.add('avatar-hidden');
        sendButton.disabled = false;

        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();

        // 检查错误
        if (data.error) {
          const errorMsg = data.error.message || JSON.stringify(data.error);
          addMessage(errorMsg, false, true);
          return;
        }

        // 读取响应内容
        const aiResponse = data.choices?.[0]?.message?.content;
        if (!aiResponse) {
          addMessage('没有收到有效回复。', false, true);
          return;
        }

        // 显示 AI 回复
        addMessage(aiResponse, false);

        // 更新历史记录（只保留用户和助手消息，不包含 system）
        historyMessages.push({ role: 'user', content: userInput });
        historyMessages.push({ role: 'assistant', content: aiResponse });

        // 限制历史消息数量
        if (historyMessages.length > MAX_HISTORY_MESSAGES * 2) {
          historyMessages = historyMessages.slice(-MAX_HISTORY_MESSAGES * 2);
        }

      } catch (error) {
        loadingIndicator.classList.add('avatar-hidden');
        sendButton.disabled = false;
        addMessage('网络请求失败，请稍后再试。', false, true);
        console.error('Chat error:', error);
      }
    }

    // 键盘事件处理
    function handleKeyDown(event) {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        sendMessage();
      }
    }

    // 绑定事件
    chatButton?.addEventListener('click', toggleChat);
    closeButton?.addEventListener('click', closeChat);
    sendButton?.addEventListener('click', sendMessage);
    inputField?.addEventListener('keydown', handleKeyDown);
    clearButton?.addEventListener('click', clearChat);
  });
</script>

<!-- 悬浮聊天按钮 -->
<button id="avatar-chat-button" class="avatar-chat-button">
